<UserControl x:Class="WordByWord.ExerciciosPainel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>

        <!-- ── Botão azul (mesmo padrão do resto do app) ── -->
        <Style x:Key="BtnAzul" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CorAcento}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="14" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3644C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão de alternativa (múltipla escolha) ── -->
        <Style x:Key="BtnAlternativa" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CorFundoPainel}"/>
            <Setter Property="Foreground" Value="{DynamicResource CorTextoPrimario}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorBorda}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="14.5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource CorAcento}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RotuloCampo" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource CorTextoSecundario}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Cabeçalho ── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Height="40" Padding="14,0" CornerRadius="14"
                    Background="{DynamicResource CorFundoIcone}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Exercícios" Foreground="{DynamicResource CorTextoPrimario}"
                               FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Margin="14,0,8,0" VerticalAlignment="Center">
                <TextBlock x:Name="lblStatus" Text="Pratique a palavra com perguntas"
                           Foreground="{DynamicResource CorTextoMuted}" FontSize="13"/>
            </StackPanel>
        </Grid>

        <!-- ── Botão voltar ── -->
        <Button Grid.Row="1" Content="← Voltar" Click="Voltar_Click"
                HorizontalAlignment="Left" Margin="0,0,0,16">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <TextBlock Text="{TemplateBinding Content}" FontSize="14"
                               Foreground="{DynamicResource CorTextoMuted}" Cursor="Hand"/>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- ═══════════════ Carregando ═══════════════ -->
        <Border x:Name="painelCarregando" Grid.Row="2"
                Background="{DynamicResource CorFundoCard}" CornerRadius="14" Padding="20"
                VerticalAlignment="Top">
            <TextBlock Text="Gerando exercício..." HorizontalAlignment="Center"
                       Foreground="{DynamicResource CorTextoMuted}" FontSize="14"/>
        </Border>

        <!-- ═══════════════ Pergunta ═══════════════ -->
        <ScrollViewer x:Name="painelPergunta" Grid.Row="2" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch">
        <StackPanel MaxWidth="560" HorizontalAlignment="Center">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblPalavra" Grid.Column="0" FontSize="26" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource CorTextoPrimario}"/>
            </Grid>

            <Grid Margin="0,6,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblProgresso" Grid.Column="0" Text="Exercício 1/5"
                           Foreground="{DynamicResource CorTextoMuted}" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblPlacar" Grid.Column="1" Text="✅ 0   ❌ 0"
                           Foreground="{DynamicResource CorTextoMuted}" FontSize="13" VerticalAlignment="Center"/>
            </Grid>

            <Border Background="{DynamicResource CorFundoCard}" CornerRadius="14" Padding="20" Margin="0,0,0,16">
                <TextBlock x:Name="lblPergunta" TextWrapping="Wrap" FontSize="16"
                           Foreground="{DynamicResource CorTextoPrimario}"/>
            </Border>

            <TextBlock Text="RESPOSTA" Style="{StaticResource RotuloCampo}"/>
            <ItemsControl x:Name="listaAlternativas"/>

        </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════ Feedback ═══════════════ -->
        <ScrollViewer x:Name="scrollFeedback" Grid.Row="2" Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="560" HorizontalAlignment="Center">
                <Border x:Name="boxResultado" CornerRadius="14" Padding="18" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="lblIconeResultado" FontSize="22" Margin="0,0,10,0"/>
                        <TextBlock x:Name="lblResultado" FontSize="17" FontWeight="Bold"
                                   VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CorFundoCard}" CornerRadius="14" Padding="20">
                    <StackPanel>
                        <TextBlock Text="RESPOSTA CORRETA" Style="{StaticResource RotuloCampo}"/>
                        <TextBlock x:Name="lblFbRespostaCorreta" TextWrapping="Wrap" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{DynamicResource CorTextoPrimario}"/>

                        <TextBlock Text="TRADUÇÃO" Style="{StaticResource RotuloCampo}" Margin="0,16,0,6"/>
                        <TextBlock x:Name="lblFbTraducao" TextWrapping="Wrap" FontSize="14"
                                   Foreground="{DynamicResource CorTextoSuave}"/>

                        <TextBlock Text="EXPLICAÇÃO DO SIGNIFICADO" Style="{StaticResource RotuloCampo}" Margin="0,16,0,6"/>
                        <TextBlock x:Name="lblFbExplicacao" TextWrapping="Wrap" FontSize="14"
                                   Foreground="{DynamicResource CorTextoSuave}"/>

                        <StackPanel x:Name="painelFbGramatica">
                            <TextBlock Text="GRAMÁTICA" Style="{StaticResource RotuloCampo}" Margin="0,16,0,6"/>
                            <TextBlock x:Name="lblFbGramatica" TextWrapping="Wrap" FontSize="14"
                                       Foreground="{DynamicResource CorTextoSuave}"/>
                        </StackPanel>

                        <TextBlock Text="EXEMPLO" Style="{StaticResource RotuloCampo}" Margin="0,16,0,6"/>
                        <Border Background="{DynamicResource CorFundoIcone}" CornerRadius="10" Padding="12,10">
                            <TextBlock x:Name="lblFbExemplo" TextWrapping="Wrap" FontSize="14"
                                       Foreground="{DynamicResource CorTextoSuave}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Button x:Name="btnContinuar" Content="Continuar" Style="{StaticResource BtnAzul}"
                        Margin="0,16,0,0" Click="Continuar_Click"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════ Resumo final ═══════════════ -->
        <StackPanel x:Name="painelResumo" Grid.Row="2" Visibility="Collapsed"
                    VerticalAlignment="Top" MaxWidth="480" HorizontalAlignment="Center">
            <Border Background="{DynamicResource CorFundoCard}" CornerRadius="14" Padding="24">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🎉" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblResumoTitulo" Text="Exercício concluído!" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,10,0,0"
                               Foreground="{DynamicResource CorTextoPrimario}"/>
                    <TextBlock x:Name="lblResumoPlacar" Text="Você acertou 0 de 0"
                               HorizontalAlignment="Center" Margin="0,6,0,0" FontSize="14"
                               Foreground="{DynamicResource CorTextoMuted}"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Voltar" Click="Voltar_Click" Style="{StaticResource BtnAzul}"/>
                <Button Grid.Column="2" Content="Praticar de novo" Click="PraticarDeNovo_Click" Style="{StaticResource BtnAzul}"/>
            </Grid>
        </StackPanel>

    </Grid>
</UserControl>
