<Application x:Class="WordByWord.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="TelaCarregamento.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="FontePadrao">Segoe UI Variable Text, Segoe UI</FontFamily>
            <FontFamily x:Key="FonteDestaque">Segoe UI Variable Display Semibold, Segoe UI Semibold, Segoe UI</FontFamily>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/TemaClaro.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
