<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- ══════════ TEMA ESCURO (padrão) ══════════ -->

    <!-- Cor de acento — mesmo azul claro usado na logo escura, para a marca ficar
         sempre alinhada às cores do app neste tema. -->
    <Color x:Key="CorAcentoCor" >#0049BF</Color>
    <SolidColorBrush x:Key="CorAcento" Color="{StaticResource CorAcentoCor}"/>

    <SolidColorBrush x:Key="CorFundoJanela"      Color="#0B1120"/>
    <SolidColorBrush x:Key="CorFundoPainel"       Color="#111827"/>
    <SolidColorBrush x:Key="CorFundoCard"         Color="#0f172a"/>
    <SolidColorBrush x:Key="CorFundoIcone"        Color="#1f2937"/>
    <SolidColorBrush x:Key="CorFundoIconeHover"   Color="#374151"/>
    <SolidColorBrush x:Key="CorFundoItemExemplo"  Color="#0d1a2e"/>

    <SolidColorBrush x:Key="CorBorda"             Color="#334155"/>
    <SolidColorBrush x:Key="CorBotaoCinzaHover"   Color="#475569"/>
    <SolidColorBrush x:Key="CorBotaoCinzaPress"   Color="#1e293b"/>

    <SolidColorBrush x:Key="CorTextoPrimario"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CorTextoSecundario"   Color="#cbd5e1"/>
    <SolidColorBrush x:Key="CorTextoMuted"        Color="#94a3b8"/>
    <SolidColorBrush x:Key="CorTextoSuave"        Color="#e2e8f0"/>

    <SolidColorBrush x:Key="CorIconeRosa"         Color="#fca5a5"/>
    <SolidColorBrush x:Key="CorIconeAzulClaro"    Color="#93c5fd"/>

    <!-- Ícone do botão de alternância de tema (lua = está no escuro, toque para clarear) -->
    <system:String x:Key="IconeAlternarTema">🌙</system:String>

</ResourceDictionary>
