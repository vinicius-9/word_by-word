<Window x:Class="WordByWord.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WordByWord"
        Title="Word By Word"
        Icon="app.ico"
        Height="660"
        Width="1060"
        MinHeight="520"
        MinWidth="480"
        Background="{DynamicResource CorFundoJanela}"
        FontFamily="{StaticResource FontePadrao}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen"
        Opacity="0"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    <Window.Resources>

        <!-- ── Card da lista de palavras: fundo + borda que reage ao mouse ── -->
        <Style x:Key="CardPalavra"
               TargetType="Border">
            <Setter Property="Background"
                    Value="{DynamicResource CorFundoCard}"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="1.5"/>
            <Setter Property="CornerRadius"
                    Value="18"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource CorAcento}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── ListBoxItem: sem highlight, sem borda ── -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Margin"
                    Value="0"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Focusable"
                    Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão Azul (Adicionar / Salvar) ── -->
        <Style x:Key="BtnAzul"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{DynamicResource CorAcento}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Height"
                    Value="44"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#3644C7"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#3644C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão (Limpar) ── -->
        <Style x:Key="BtnAzulLimpa"
               TargetType="Button"
               BasedOn="{StaticResource BtnAzul}">
            <Setter Property="Background"
                    Value="{DynamicResource CorAcento}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#3644C7"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#3644C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão "fantasma" (Cancelar em diálogos) ── -->
        <Style x:Key="BtnFantasmaDialogo"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{DynamicResource CorFundoIcone}"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource CorTextoSuave}"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Height"
                    Value="42"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource CorFundoIconeHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão vermelho (Remover no detalhe) ── -->
        <Style x:Key="BtnVermelho"
               TargetType="Button"
               BasedOn="{StaticResource BtnAzul}">
            <Setter Property="Background"
                    Value="#7f1d1d"/>
            <Setter Property="Foreground"
                    Value="#fca5a5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#991b1b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão de ícone (editar/remover na lista) ── -->
        <Style x:Key="BtnIcone"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{DynamicResource CorFundoIcone}"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Width"
                    Value="36"/>
            <Setter Property="Height"
                    Value="36"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource CorFundoIconeHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Botão Voltar (link-style) ── -->
        <Style x:Key="BtnVoltar"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource CorTextoMuted}"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="tb"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="tb"
                                        Property="Foreground"
                                        Value="{DynamicResource CorTextoPrimario}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Campo do novo formulário: cantos arredondados, realça a borda ao focar ── -->
        <Style x:Key="CampoFormularioNovo" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CorFundoPainel}"/>
            <Setter Property="Foreground" Value="{DynamicResource CorTextoPrimario}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource CorTextoPrimario}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CorBorda}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource CorAcento}"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Caixa de busca com texto de dica (usa Tag como placeholder) ── -->
        <Style x:Key="TxtBuscaComDica"
               TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <TextBlock Text="{TemplateBinding Tag}"
                                       Foreground="{DynamicResource CorTextoMuted}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}"
                                                         Value="">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Papel / Página (ícone dos cards de palavra) ── -->
        <DrawingImage x:Key="IconePagina">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#e2e8f0"
                                     Geometry="M 4,1 L 16,1 L 20,5 L 20,23 L 4,23 Z"/>
                    <GeometryDrawing Brush="#94a3b8"
                                     Geometry="M 16,1 L 16,5 L 20,5 Z"/>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#64748b"
                                 Thickness="0.6"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <PathGeometry>
                                <PathFigure StartPoint="16,1">
                                    <LineSegment Point="16,5"/>
                                    <LineSegment Point="20,5"/>
                                </PathFigure>
                            </PathGeometry>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#64748b"
                                 Thickness="1.4"
                                 StartLineCap="Round"
                                 EndLineCap="Round"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="7,9"
                                              EndPoint="17,9"/>
                                <LineGeometry StartPoint="7,12"
                                              EndPoint="17,12"/>
                                <LineGeometry StartPoint="7,15"
                                              EndPoint="13,15"/>
                                <LineGeometry StartPoint="7,18"
                                              EndPoint="15,18"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

    </Window.Resources>

    <!-- LAYOUT PRINCIPAL-->
    <Grid Margin="20">


        <!-- PAINEL PRINCIPAL — Lista / Detalhe / Formulário / Assistente -->
        <Border Background="{DynamicResource CorFundoPainel}"
                CornerRadius="28"
                Padding="24"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabeçalho (responsivo: os botões quebram para uma nova linha se a janela ficar estreita) -->
                <Grid Grid.Row="0"
                      Margin="0,0,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="lblTitulo"
                                       Text="Palavras cadastradas"
                                       FontFamily="{StaticResource FonteDestaque}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource CorTextoPrimario}"/>
                            <TextBlock x:Name="lblSub"
                                       Text="Clique em uma palavra para ver os detalhes"
                                       Foreground="{DynamicResource CorTextoMuted}"
                                       FontSize="13"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Botão de canto: tema -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                            <Button x:Name="btnTemaCanto"
                                    Content="{DynamicResource IconeAlternarTema}"
                                    Click="Tema_Click"
                                    Width="40" Height="40"
                                    Background="{DynamicResource CorFundoIcone}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Trocar tema claro/escuro">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="14"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background"
                                                        Value="{DynamicResource CorFundoIconeHover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1"
                                  Margin="0,14,0,0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  PanningMode="HorizontalOnly">
                    <StackPanel Orientation="Horizontal">
                        <!-- Contador "N palavras" — badge próprio, separado do Assistente -->
                        <Border Background="{DynamicResource CorFundoIcone}"
                                CornerRadius="14"
                                Height="40"
                                Padding="14,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="6" Height="6" Fill="#7C9AFF"
                                         VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock x:Name="lblTotal"
                                           Foreground="{DynamicResource CorTextoSecundario}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Nova palavra — abre o formulário manual (palavra, significado, exemplo) -->
                        <Button x:Name="btnNovaPalavra"
                                Click="NovaPalavra_Click"
                                Margin="10,0,0,0"
                                Height="40"
                                Padding="16,0"
                                Background="{DynamicResource CorFundoIcone}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Cadastrar uma nova palavra">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="14"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="13" Height="13" Margin="0,0,8,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="{DynamicResource CorTextoPrimario}"
                                                          Data="M11 4H13V11H20V13H13V20H11V13H4V11H11Z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="Nova palavra"
                                                       Foreground="{DynamicResource CorTextoPrimario}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource CorFundoIconeHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Conversa — atalho que abre o assistente já direto na conversa -->
                        <Button x:Name="btnConversa"
                                Click="Conversa_Click"
                                Margin="8,0,0,0"
                                Height="40"
                                Padding="14,0"
                                Background="{DynamicResource CorFundoIcone}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Bate-papo em inglês pra praticar">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="14"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="{DynamicResource CorAcento}" StrokeThickness="2" StrokeLineJoin="Round"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                          Data="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="Bate-papo inglês"
                                                       Foreground="{DynamicResource CorTextoPrimario}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource CorFundoIconeHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Assistente — tira dúvidas de inglês -->
                        <Button x:Name="btnAssistente"
                                Click="Assistente_Click"
                                Margin="10,0,0,0"
                                Height="40"
                                Padding="14,0"
                                Background="{DynamicResource CorFundoIcone}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Abrir o assistente">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="14"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="{DynamicResource CorAcento}" Data="M9 4.5a.75.75 0 01.721.544l.813 2.846a3.75 3.75 0 002.576 2.576l2.846.813a.75.75 0 010 1.442l-2.846.813a3.75 3.75 0 00-2.576 2.576l-.813 2.846a.75.75 0 01-1.442 0l-.813-2.846a3.75 3.75 0 00-2.576-2.576l-2.846-.813a.75.75 0 010-1.442l2.846-.813A3.75 3.75 0 007.5 7.89l.813-2.846A.75.75 0 019 4.5zM18 1.5a.75.75 0 01.728.568l.258 1.036c.236.94.97 1.674 1.91 1.91l1.036.258a.75.75 0 010 1.456l-1.036.258c-.94.236-1.674.97-1.91 1.91l-.258 1.036a.75.75 0 01-1.456 0l-.258-1.036a2.625 2.625 0 00-1.91-1.91l-1.036-.258a.75.75 0 010-1.456l1.036-.258a2.625 2.625 0 001.91-1.91l.258-1.036A.75.75 0 0118 1.5zM16.5 15a.75.75 0 01.712.513l.394 1.183c.15.447.5.799.949.948l1.183.395a.75.75 0 010 1.422l-1.183.395c-.447.15-.799.5-.948.949l-.395 1.183a.75.75 0 01-1.422 0l-.395-1.183a1.5 1.5 0 00-.949-.948l-1.183-.395a.75.75 0 010-1.422l1.183-.395c.447-.15.799-.5.948-.949l.395-1.183A.75.75 0 0116.5 15z"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="Assistente"
                                                       Foreground="{DynamicResource CorTextoPrimario}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource CorFundoIconeHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>


                    </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Barra de busca (fica junto da lista de palavras, com mais espaço agora que o formulário é escondido) -->
                <Grid Grid.Row="1"
                      Margin="0,0,0,16">
                    <Border Background="{DynamicResource CorFundoIcone}"
                            CornerRadius="14"
                            Padding="14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Viewbox Grid.Column="0"
                                     Width="18"
                                     Height="18"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center">
                                <Canvas Width="24"
                                        Height="24">
                                    <Path Fill="#9AA0A6"
                                          Data="M15.5,14H14.71L14.43,13.73A6.5,6.5 0 1 0 13.73,14.43L14,14.71V15.5L19,20.49L20.49,19L15.5,14ZM9.5,14A4.5,4.5 0 1 1 14,9.5A4.5,4.5 0 0 1 9.5,14Z"/>
                                </Canvas>
                            </Viewbox>










                            <TextBox x:Name="txtBusca"
                                     Grid.Column="1"
                                     Style="{StaticResource TxtBuscaComDica}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource CorTextoPrimario}"
                                     CaretBrush="{DynamicResource CorTextoPrimario}"
                                     Height="42"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"
                                     Tag="Buscar por palavra ou significado..."
                                     TextChanged="Buscar_TextChanged"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ─── VISÃO LISTA ─── -->
                <ScrollViewer x:Name="scrollLista"
                              Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              CanContentScroll="False">
                    <ListBox x:Name="listaPalavras"
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionMode="Single"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             PreviewMouseWheel="ListaPalavras_PreviewMouseWheel">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:Palavra}">
                                <Border Style="{StaticResource CardPalavra}"
                                        Padding="18,16"
                                        Margin="0,0,0,12"
                                        Cursor="Hand"
                                        MinWidth="420"
                                        MouseLeftButtonUp="ItemCard_MouseLeftButtonUp">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="46"
                                                Height="46"
                                                CornerRadius="14"
                                                Background="{DynamicResource CorAcento}"
                                                VerticalAlignment="Center">
                                            <Image Source="{StaticResource IconePagina}"
                                                   Width="26"
                                                   Height="26"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="14,0,12,0">
                                            <TextBlock Text="{Binding PalavraTexto}"
                                                       Foreground="{DynamicResource CorTextoPrimario}"
                                                       FontFamily="{StaticResource FonteDestaque}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Significado}"
                                                       Foreground="{DynamicResource CorTextoSecundario}"
                                                       FontSize="13.5"
                                                       TextWrapping="Wrap"
                                                       Margin="0,5,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Content="&#xE767;"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    Foreground="{DynamicResource CorAcento}"
                                                    ToolTip="Ouvir pronúncia"
                                                    Style="{StaticResource BtnIcone}"
                                                    Click="OuvirItem_Click"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="&#xE70F;"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    Foreground="{DynamicResource CorIconeAzulClaro}"
                                                    ToolTip="Editar"
                                                    Style="{StaticResource BtnIcone}"
                                                    Margin="8,0,0,0"
                                                    Click="EditarItem_Click"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="&#xE74D;"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    Foreground="#f87171"
                                                    ToolTip="Remover"
                                                    Style="{StaticResource BtnIcone}"
                                                    Margin="8,0,0,0"
                                                    Click="RemoverItem_Click"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- ─── VISÃO DETALHE ─── -->
                <ScrollViewer x:Name="scrollDetalhe"
                              Grid.Row="2"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Border x:Name="painelDetalhe"
                            Background="{DynamicResource CorFundoCard}"
                            CornerRadius="20"
                            Padding="28">
                        <StackPanel>

                            <!-- Botão voltar -->
                            <Button Content="← Voltar para a lista"
                                    Style="{StaticResource BtnVoltar}"
                                    Click="Voltar_Click"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,24"/>

                            <!-- Ícone papel grande -->
                            <Border Width="72"
                                    Height="72"
                                    CornerRadius="20"
                                    Background="{DynamicResource CorAcento}"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,20">
                                <Image Source="{StaticResource IconePagina}"
                                       Width="42"
                                       Height="42"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <!-- Nome da palavra + botão de pronúncia -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="lblDetalhePalavra" Grid.Column="0"
                                           Foreground="{DynamicResource CorTextoPrimario}"
                                           FontFamily="{StaticResource FonteDestaque}"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="btnOuvirDetalhe" Grid.Column="1"
                                        Click="OuvirDetalhe_Click"
                                        Width="44" Height="44" Margin="12,0,0,0"
                                        Background="{DynamicResource CorFundoIcone}"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="Ouvir pronúncia">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    CornerRadius="22" SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource CorFundoIconeHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>

                                    <Grid>
                                        <Viewbox x:Name="iconeOuvir" Width="18" Height="18">
                                            <Canvas Width="24" Height="24">
                                                <Path Fill="{DynamicResource CorAcento}" Data="M11 5 6 9H3v6h3l5 4Z"/>
                                                <Path Stroke="{DynamicResource CorAcento}" StrokeThickness="2" Fill="Transparent"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Data="M15.5 8.5a5 5 0 0 1 0 7"/>
                                                <Path Stroke="{DynamicResource CorAcento}" StrokeThickness="2" Fill="Transparent"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Data="M18 5.5a9 9 0 0 1 0 13"/>
                                            </Canvas>
                                        </Viewbox>
                                        <Viewbox x:Name="iconeCarregandoAudio" Width="16" Height="16" Visibility="Collapsed">
                                            <Canvas Width="24" Height="24">
                                                <Ellipse Width="20" Height="20" Canvas.Left="2" Canvas.Top="2"
                                                         Stroke="{DynamicResource CorAcento}" StrokeThickness="3" StrokeDashArray="4,3"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                </Button>
                            </Grid>

                            <!-- Significado -->
                            <Border Background="{DynamicResource CorFundoPainel}"
                                    CornerRadius="14"
                                    Padding="18"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="SIGNIFICADO"
                                               Foreground="{DynamicResource CorAcento}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Margin="0,0,0,8"/>
                                    <TextBlock x:Name="lblDetalheSignificado"
                                               Foreground="{DynamicResource CorTextoSuave}"
                                               FontSize="16"
                                               TextWrapping="Wrap"
                                               LineHeight="24"/>
                                </StackPanel>
                            </Border>
                            <!-- EXEMPLO — um único bloco de texto corrido, em vez de um card por parágrafo -->
                            <Border x:Name="boxExemplo"
                                    Background="{DynamicResource CorFundoPainel}"
                                    CornerRadius="14"
                                    Padding="18"
                                    Margin="0,0,0,28"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="EXEMPLO"
                                               Foreground="{DynamicResource CorAcento}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Margin="0,0,0,10"/>

                                    <TextBlock x:Name="lblDetalheExemplo"
                                               Foreground="{DynamicResource CorTextoSuave}"
                                               FontSize="15"
                                               TextWrapping="Wrap"
                                               LineHeight="23"/>

                                </StackPanel>
                            </Border>

                            <!-- Múltiplos sentidos da palavra (ex.: work = trabalhar / funcionar / malhar) -->
                            <Border x:Name="boxSentidos"
                                    Background="{DynamicResource CorFundoPainel}"
                                    CornerRadius="14"
                                    Padding="18"
                                    Margin="0,0,0,28"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="SIGNIFICADOS POR CONTEXTO"
                                               Foreground="{DynamicResource CorAcento}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="listaDetalheSentidos">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CorFundoItemExemplo}"
                                                        CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Significado}" FontSize="15" FontWeight="Bold"
                                                                   Foreground="{DynamicResource CorTextoPrimario}"/>
                                                        <TextBlock Text="{Binding Exemplo}" FontSize="14" TextWrapping="Wrap"
                                                                   FontStyle="Italic" Foreground="{DynamicResource CorTextoMuted}"
                                                                   Margin="0,4,0,0"/>
                                                        <TextBlock Text="{Binding QuandoUsar}" FontSize="12.5" TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource CorTextoMuted}" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Expressões idiomáticas relacionadas (ex.: "work out", "work on") -->
                            <Border x:Name="boxExpressoesDetalhe"
                                    Background="{DynamicResource CorFundoPainel}"
                                    CornerRadius="14"
                                    Padding="18"
                                    Margin="0,0,0,28"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="EXPRESSÕES"
                                               Foreground="{DynamicResource CorAcento}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="listaDetalheExpressoes">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat='•  {0}'}"
                                                           FontSize="15" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource CorTextoSuave}"
                                                           Margin="0,0,0,6"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Dica curta para ajudar a decorar a palavra -->
                            <Border x:Name="boxDicaDetalhe"
                                    Background="{DynamicResource CorFundoPainel}"
                                    CornerRadius="14"
                                    Padding="18"
                                    Margin="0,0,0,28"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="DICA PARA DECORAR"
                                               Foreground="{DynamicResource CorAcento}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Margin="0,0,0,10"/>
                                    <Border Background="{DynamicResource CorFundoItemExemplo}"
                                            CornerRadius="8" Padding="12,10">
                                        <TextBlock x:Name="lblDetalheDica"
                                                   FontSize="15" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource CorTextoSuave}"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Botões de ação no detalhe -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="Gerar exercício"
                                        Style="{StaticResource BtnAzul}"
                                        Click="ExerciciosDetalhe_Click"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="✏ Editar"
                                        Style="{StaticResource BtnAzulLimpa}"
                                        Click="EditarDetalhe_Click"/>
                                <Button Grid.Column="2"
                                        Content="🗑 Remover"
                                        Style="{StaticResource BtnVermelho}"
                                        Click="RemoverDetalhe_Click"/>
                            </Grid>

                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <!-- ─── VISÃO EXERCÍCIOS ─── -->
                <local:ExerciciosPainel x:Name="painelExercicios"
                                        Grid.Row="2"
                                        Visibility="Collapsed"/>

                <!-- ─── VISÃO FORMULÁRIO (Nova palavra / Editar palavra) — ocupa a tela toda ─── -->
                <Grid x:Name="painelFormulario"
                      Grid.Row="2"
                      Visibility="Collapsed">
                    <Border Background="{DynamicResource CorFundoCard}"
                            CornerRadius="20"
                            Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Botão voltar (mesmo padrão do detalhe/assistente) -->
                            <Button Grid.Row="0"
                                    Content="← Voltar para a lista"
                                    Style="{StaticResource BtnVoltar}"
                                    Click="FormularioVoltar_Click"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,16"/>

                            <!-- Cabeçalho simples: só título e subtítulo, sem ícone -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                                <TextBlock x:Name="lblFormularioTitulo"
                                           Text="Nova palavra"
                                           FontFamily="{StaticResource FonteDestaque}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource CorTextoPrimario}"/>
                                <TextBlock x:Name="lblFormularioSub"
                                           Text="Cadastre uma nova palavra no seu dicionário"
                                           FontSize="13"
                                           Foreground="{DynamicResource CorTextoMuted}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Campos (com scroll próprio caso a janela fique baixa) -->
                            <ScrollViewer Grid.Row="2"
                                          x:Name="scrollCamposFormulario"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>

                                    <!-- Palavra + Significado lado a lado, aproveitando a largura toda -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="PALAVRA"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource CorTextoSecundario}"
                                                       Margin="0,0,0,6"/>
                                            <TextBox x:Name="txtPalavra"
                                                     Style="{StaticResource CampoFormularioNovo}"
                                                     Height="44"/>
                                            <Button x:Name="btnGerarComIA"
                                                    Content="✨ Gerar com IA"
                                                    Click="GerarComIA_Click"
                                                    Height="30"
                                                    FontSize="12"
                                                    Margin="0,8,0,0"
                                                    HorizontalAlignment="Left"
                                                    Padding="12,0"
                                                    Background="{DynamicResource CorFundoIcone}"
                                                    Foreground="{DynamicResource CorTextoPrimario}"
                                                    BorderBrush="Transparent"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="10"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="SIGNIFICADO"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource CorTextoSecundario}"
                                                       Margin="0,0,0,6"/>
                                            <TextBox x:Name="txtSignificado"
                                                     Style="{StaticResource CampoFormularioNovo}"
                                                     Height="44"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Exemplo — ocupa a largura toda, com mais espaço para escrever -->
                                    <TextBlock Text="EXEMPLO (OPCIONAL)"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource CorTextoSecundario}"
                                               Margin="0,0,0,6"/>
                                    <TextBox x:Name="txtExemplo"
                                             Style="{StaticResource CampoFormularioNovo}"
                                             MinHeight="80"
                                             VerticalContentAlignment="Top"
                                             Padding="14,12"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- Botões -->
                            <Grid Grid.Row="3" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="Limpar"
                                        Click="Limpar_Click"
                                        Height="44"
                                        FontSize="14"
                                        Style="{StaticResource BtnAzulLimpa}"/>
                                <Button x:Name="btnAdicionar"
                                        Grid.Column="2"
                                        Content="Adicionar"
                                        Click="Adicionar_Click"
                                        Height="44"
                                        FontSize="14"
                                        Style="{StaticResource BtnAzul}"/>
                            </Grid>

                        </Grid>
                    </Border>
                </Grid>

                <!-- ─── VISÃO ASSISTENTE ─── -->
                <local:AssistentePainel x:Name="painelAssistente"
                                        Grid.Row="2"
                                        Visibility="Collapsed"/>

            </Grid>
        </Border>

        <!-- ─── OVERLAY: PALAVRA JÁ CADASTRADA (aparece por cima de tudo) ─── -->
        <Grid x:Name="overlayPalavraDuplicada"
              Background="#99000000"
              Visibility="Collapsed">
            <Border Background="{DynamicResource CorFundoPainel}"
                    BorderBrush="{DynamicResource CorBorda}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="26"
                    Width="380"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black"
                                      Opacity="0.4"
                                      BlurRadius="28"
                                      ShadowDepth="6"/>
                </Border.Effect>
                <StackPanel>
                    <Border Width="52"
                            Height="52"
                            CornerRadius="16"
                            Background="#f59e0b"
                            Margin="0,0,0,16">
                        <TextBlock Text="&#xE7BA;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="24"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Essa palavra já está cadastrada"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource CorTextoPrimario}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="lblPalavraDuplicadaInfo"
                               Foreground="{DynamicResource CorTextoMuted}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <Button x:Name="btnDuplicadaAtualizar"
                            Content="Atualizar a palavra existente"
                            Style="{StaticResource BtnAzul}"
                            Click="DuplicadaAtualizar_Click"
                            Margin="0,0,0,10"/>
                    <Button x:Name="btnDuplicadaNovaMesmoAssim"
                            Content="Cadastrar mesmo assim (duplicar)"
                            Style="{StaticResource BtnAzulLimpa}"
                            Click="DuplicadaCadastrarMesmoAssim_Click"
                            Margin="0,0,0,10"/>
                    <Button Content="Cancelar"
                            Style="{StaticResource BtnFantasmaDialogo}"
                            Click="DuplicadaCancelar_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ─── TOAST — notificação estilizada (substitui o MessageBox do Windows) ─── -->
        <Grid x:Name="overlayToast"
              Background="Transparent"
              IsHitTestVisible="False"
              VerticalAlignment="Bottom"
              HorizontalAlignment="Center"
              Margin="0,0,0,32">
            <Border x:Name="cardToast"
                    CornerRadius="16"
                    Padding="18,14"
                    MinWidth="260"
                    MaxWidth="440"
                    Visibility="Collapsed"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="transformToast"
                                        Y="30"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect Color="Black"
                                      Opacity="0.35"
                                      BlurRadius="20"
                                      ShadowDepth="6"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="iconeToastFundo"
                            Width="30"
                            Height="30"
                            CornerRadius="10"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="iconeToast"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="textoToast"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ─── OVERLAY: CONFIRMAR REMOÇÃO DE PALAVRA — estilo do app ─── -->
        <Grid x:Name="overlayConfirmarRemocao"
              Background="#99000000"
              Visibility="Collapsed">
            <Border Background="{DynamicResource CorFundoPainel}"
                    BorderBrush="{DynamicResource CorBorda}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="26"
                    Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black"
                                      Opacity="0.4"
                                      BlurRadius="28"
                                      ShadowDepth="6"/>
                </Border.Effect>
                <StackPanel>
                    <Border Width="52"
                            Height="52"
                            CornerRadius="16"
                            Background="#7f1d1d"
                            Margin="0,0,0,16">
                        <TextBlock Text="&#xE74D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="22"
                                   Foreground="#fca5a5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Remover palavra"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource CorTextoPrimario}"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="lblConfirmarRemocaoInfo"
                               Foreground="{DynamicResource CorTextoMuted}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Cancelar"
                                Style="{StaticResource BtnFantasmaDialogo}"
                                Click="RemocaoCancelar_Click"/>
                        <Button Grid.Column="2"
                                Content="Remover"
                                Style="{StaticResource BtnVermelho}"
                                Click="RemocaoConfirmar_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
